{
  "name": "multi-agent-playground",
  "private": true,
  "workspaces": ["packages/*"],
  "scripts": {
    "build": "bun run --filter '@playground/shared' build && bun run --filter '*' build",
    "test": "bun run --filter '*' test",
    "lint": "bunx biome check .",
    "lint:fix": "bunx biome check --write .",
    "dev:api": "cd packages/api && bun run dev",
    "dev:ui": "cd packages/ui && bun run dev"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/bun": "latest",
    "typescript": "^5.7.0"
  }
}
